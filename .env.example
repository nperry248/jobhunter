# ─────────────────────────────────────────────────────────────
# .env.example — Template for environment variables
#
# HOW TO USE:
#   1. Copy this file: `cp .env.example .env`
#   2. Fill in the real values in .env
#   3. NEVER commit .env — it's in .gitignore
#   4. .env.example IS safe to commit (no real secrets here)
# ─────────────────────────────────────────────────────────────


# ── AI ──────────────────────────────────────────────────────
# Your Anthropic API key. Get it at: https://console.anthropic.com
# Used by: Resume Match Agent, Outreach Agent
ANTHROPIC_API_KEY=sk-ant-your-key-here


# ── Database ─────────────────────────────────────────────────
# PostgreSQL connection string. Format: postgresql+asyncpg://user:pass@host:port/dbname
# The `+asyncpg` tells SQLAlchemy to use the async driver (required for FastAPI).
# For local Docker: use the values from docker-compose.yml
DATABASE_URL=postgresql+asyncpg://jobhunter:jobhunter@localhost:5432/jobhunter

# A separate DB for running tests — NEVER point this at your real dev DB.
# Tests create and drop tables freely, which would destroy real data.
TEST_DATABASE_URL=postgresql+asyncpg://jobhunter:jobhunter@localhost:5432/jobhunter_test


# ── Redis / Task Queue ────────────────────────────────────────
# Redis connection string. Used by Celery as the message broker.
# Database 0 = default; database 1 = reserved for Celery results backend
REDIS_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1


# ── API Server ────────────────────────────────────────────────
# The host/port the FastAPI server binds to.
# BACKEND_CORS_ORIGINS is a comma-separated list of allowed frontend origins.
# This prevents random websites from making API requests to your backend.
API_HOST=0.0.0.0
API_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000


# ── Agent Behavior ────────────────────────────────────────────
# How many jobs to scrape per run (prevents runaway scraping)
SCRAPER_MAX_JOBS_PER_RUN=100

# Minimum score (0–100) a job must have to be auto-applied to
MATCH_SCORE_THRESHOLD=70

# Max retries for any external HTTP call before giving up
MAX_RETRY_ATTEMPTS=3

# Base delay (seconds) for exponential backoff between retries
# Retry 1 waits 1s, retry 2 waits 2s, retry 3 waits 4s (doubles each time)
RETRY_BASE_DELAY=1.0

# How often (in seconds) the scraper runs. 3600 = once per hour.
SCRAPER_INTERVAL_SECONDS=3600

# Timeout in seconds for each outbound HTTP request to a job board API.
SCRAPER_REQUEST_TIMEOUT=30


# ── Scraper — Company Slugs ───────────────────────────────────
# JSON dict of {slug: "Human Name"} pairs for each platform.
# The slug is the company identifier in the job board URL.
#
# Finding a slug:
#   Greenhouse: https://boards.greenhouse.io/{slug}
#   Lever:      https://jobs.lever.co/{slug}
#
# Add/remove companies here without touching any Python code.
GREENHOUSE_SLUGS={"airbnb": "Airbnb", "figma": "Figma", "ramp": "Ramp", "coinbase": "Coinbase", "plaid": "Plaid"}
LEVER_SLUGS={"notion": "Notion"}


# ── Logging ───────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
